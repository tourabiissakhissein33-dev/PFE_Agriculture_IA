# 1. Courbes apprentissage
ep = range(1, len(hist['accuracy'])+1)
axes[0].plot(ep, hist['accuracy'],     'b-', lw=2, label='Train')
axes[0].plot(ep, hist['val_accuracy'], 'r-', lw=2, label='Validation')
axes[0].axvline(ep_p1, color='gray', ls='--', lw=1.5,
