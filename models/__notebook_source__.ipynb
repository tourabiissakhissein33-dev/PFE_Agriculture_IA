# CELLULE 2 — Chargement et vérification du dataset
# ══════════════════════════════════════════════════════════════════

DATASET = "/kaggle/input/datasets/tourabiissakhissein/maladies-cultures-tchad/dataset_tchad_maladies"

# Mapping des noms EXACTS de vos dossiers → labels unifiés
# (corrige l'incohérence Sain/Saine dans vos dossiers)
MAPPING = {
    "Mais_Sain":       "Mais_Saine",
    "Mais_Malade":     "Mais_Malade",
    "Mil_Sain":        "Mil_Saine",
    "Mil_Malade":      "Mil_Malade",
    "Sorgho_Saine":    "Sorgho_Saine",
    "Sorgho_Malade":   "Sorgho_Malade",
    "Arachide_Saine":  "Arachide_Saine",
    "Arachide_Malade": "Arachide_Malade",
    "Coton_Sain":      "Coton_Saine",
    "Coton_Malade":    "Coton_Malade",
}

print(f"\n  Scan du dataset : {DATASET}")
print(f"  {'='*50}")

rows = []
for dossier, label in MAPPING.items():
    chemin = os.path.join(DATASET, dossier)
    if not os.path.exists(chemin):
        print(f"  ⚠ Non trouvé : {dossier}/")
        continue
    imgs = [f for f in os.listdir(chemin)
            if f.lower().endswith(('.jpg','.jpeg','.png','.JPG'))]
    for img in imgs:
        rows.append({
            'filepath': os.path.join(chemin, img),
            'label':    label,
        })
    e = "✅" if "Saine" in label else "🦠"
    print(f"  {e} {dossier:<22} → {label:<22} : {len(imgs):>3} images")

df_all = pd.DataFrame(rows)
df_all = df_all.sample(frac=1, random_state=42).reset_index(drop=True)

print(f"\n  {'='*50}")
print(f"  TOTAL : {len(df_all)} images")
print(f"  Classes : {df_all['label'].nunique()}")




# ══════════════════════════════════════════════════════════════════
# CELLULE 3 — Split train/val/test
# ══════════════════════════════════════════════════════════════════

# Vérifier les classes avec assez d'images (min 6 pour le split)
counts        = df_all['label'].value_counts()
classes_ok    = counts[counts >= 6].index.tolist()
df_ok         = df_all[df_all['label'].isin(classes_ok)].copy()
classes_ignorees = [c for c in df_all['label'].unique()
                    if c not in classes_ok]

if classes_ignorees:
    print(f"\n  ⚠ Classes ignorées (< 6 images) : {classes_ignorees}")

print(f"\n  Split 70 / 15 / 15 :")
df_tr, df_te = train_test_split(
    df_ok, test_size=0.15, random_state=42, stratify=df_ok['label'])
df_tr, df_va = train_test_split(
    df_tr, test_size=0.176, random_state=42, stratify=df_tr['label'])

print(f"    Train : {len(df_tr)}")
print(f"    Val   : {len(df_va)}")
print(f"    Test  : {len(df_te)}")

CLASSES_REEL = sorted(df_ok['label'].unique().tolist())
N_CLS        = len(CLASSES_REEL)
print(f"    Classes effectives : {N_CLS}")

# Class weights
cw_arr = compute_class_weight(
    'balanced',
    classes=np.array(CLASSES_REEL),
    y=df_tr['label'].values
)
class_weight_dict = {i: w for i, w in enumerate(cw_arr)}
print(f"\n  Class weights (corrige le déséquilibre) :")
for cls, w in zip(CLASSES_REEL, cw_arr):
    print(f"    {cls:<22} : {w:.3f}")


 



# ══════════════════════════════════════════════════════════════════
# CELLULE 4 — Équilibrage intelligent
# ══════════════════════════════════════════════════════════════════
 
print("\n" + "="*60)
print("  ÉQUILIBRAGE DES CLASSES")
print("="*60)
 # ══════════════════════════════════════════════════════════════════
# CELLULE 4 — Générateurs avec augmentation FORTE
# ══════════════════════════════════════════════════════════════════

# Augmentation très forte car peu d'images (25–40 par classe)
# Chaque image réelle génère ~15 variantes différentes
aug_train = ImageDataGenerator(
    rescale=1./255,
    rotation_range=45,           # feuille photographiée sous diff. angles
    width_shift_range=0.25,
    height_shift_range=0.25,
    horizontal_flip=True,
    vertical_flip=True,          # feuille retournée = image valide
    zoom_range=0.30,
    brightness_range=[0.4, 1.6], # fort soleil vs ombre (conditions Tchad)
    shear_range=0.20,
    channel_shift_range=35,      # variation lumière matin/soir
    fill_mode='nearest'
)
aug_val = ImageDataGenerator(rescale=1./255)

gen_tr = aug_train.flow_from_dataframe(
    df_tr, x_col='filepath', y_col='label',
    target_size=IMG_SIZE, batch_size=BATCH_SIZE,
    class_mode='categorical', shuffle=True)

gen_va = aug_val.flow_from_dataframe(
    df_va, x_col='filepath', y_col='label',
    target_size=IMG_SIZE, batch_size=BATCH_SIZE,
    class_mode='categorical', shuffle=False)

gen_te = aug_val.flow_from_dataframe(
    df_te, x_col='filepath', y_col='label',
    target_size=IMG_SIZE, batch_size=BATCH_SIZE,
    class_mode='categorical', shuffle=False)

# Mettre à jour N_CLS depuis le générateur
N_CLS        = len(gen_tr.class_indices)
CLASSES_REEL = list(gen_tr.class_indices.keys())

print(f"\n✅ Générateurs créés — {N_CLS} classes")
print(f"   Augmentation forte activée (×15 par image)")




 
# ══════════════════════════════════════════════════════════════════
# CELLULE 5 — Générateurs avec augmentation africaine
# ══════════════════════════════════════════════════════════════════
 
aug_train = ImageDataGenerator(
    rescale=1./255,
    rotation_range=30,
    width_shift_range=0.15,
    height_shift_range=0.15,
    horizontal_flip=True,
    zoom_range=0.20,
    brightness_range=[0.65, 1.35],  # fort ensoleillement africain
    shear_range=0.10)# ══════════════════════════════════════════════════════════════════
# CELLULE 5 — Modèle MobileNetV2
# ══════════════════════════════════════════════════════════════════

class SaveBest(keras.callbacks.Callback):
    """Sauvegarde après chaque epoch — résistant aux déconnexions."""
    def __init__(self, prefix):
        super().__init__()
        self.prefix   = prefix
        self.best_acc = 0.0
        self.best_ep  = 0

    def on_epoch_end(self, epoch, logs=None):
        va = (logs or {}).get('val_accuracy', 0)
        self.model.save(f'{self.prefix}_last.keras')
        if va > self.best_acc:
            self.best_acc = va
            self.best_ep  = epoch + 1
            self.model.save(f'{self.prefix}_best.keras')
            print(f'\n  💾 BEST ep.{epoch+1} → val_acc={va*100:.2f}%')

    def on_train_end(self, logs=None):
        print(f'\n  ✅ Meilleure val_accuracy : '
              f'{self.best_acc*100:.2f}% (epoch {self.best_ep})')


# Construire MobileNetV2
base = MobileNetV2(input_shape=(*IMG_SIZE, 3),
                   include_top=False, weights='imagenet')
base.trainable = False   # Phase 1 : base gelée

inp = keras.Input(shape=(*IMG_SIZE, 3))
x   = base(inp, training=False)
x   = layers.GlobalAveragePooling2D()(x)
x   = layers.Dense(256, activation='relu')(x)
x   = layers.BatchNormalization()(x)
x   = layers.Dropout(0.5)(x)      # fort dropout car peu d'images
x   = layers.Dense(128, activation='relu')(x)
x   = layers.BatchNormalization()(x)
x   = layers.Dropout(0.4)(x)
out = layers.Dense(N_CLS, activation='softmax')(x)

model = keras.Model(inp, out)
model.compile(
    optimizer=keras.optimizers.Adam(1e-3),
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

total     = model.count_params()
trainable = sum(tf.size(w).numpy() for w in model.trainable_weights)
print(f"\n✅ Modèle MobileNetV2 construit")
print(f"   Paramètres totaux       : {total:,}")
print(f"   Paramètres entraînables : {trainable:,}")
print(f"   N classes               : {N_CLS}")




# ══════════════════════════════════════════════════════════════════
# CELLULE 6 — Phase 1 : entraîner la tête
# ══════════════════════════════════════════════════════════════════

print("\n" + "="*60)
print("  PHASE 1 — Entraînement tête CNN (base gelée)")
print("  Données : uniquement votre dataset local tchadien")
print("="*60)

CKPT = '/kaggle/working/cnn_tchad'

cb1 = [
    SaveBest(CKPT),
    EarlyStopping(monitor='val_accuracy', patience=10,
                  restore_best_weights=True, verbose=0),
    ReduceLROnPlateau(monitor='val_loss', factor=0.5,
                      patience=5, min_lr=1e-6, verbose=1),
]

history1 = model.fit(
    gen_tr,
    epochs=40,             # plus d'epochs pour peu d'images
    validation_data=gen_va,
    callbacks=cb1,
    class_weight=class_weight_dict,
    verbose=1
)
acc_p1 = max(history1.history['val_accuracy'])
model.save(f'{CKPT}_phase1_final.keras')
print(f"\n✅ Phase 1 : val_accuracy = {acc_p1*100:.2f}%")


 


# ══════════════════════════════════════════════════════════════════
# CELLULE 7 — Phase 2 : Fine-tuning
# ══════════════════════════════════════════════════════════════════

print("\n" + "="*60)
print("  PHASE 2 — Fine-tuning (30 dernières couches)")
print("="*60)

# Recharger le meilleur modèle Phase 1
if os.path.exists(f'{CKPT}_best.keras'):
    model = keras.models.load_model(f'{CKPT}_best.keras')
    print("✅ Meilleur modèle Phase 1 rechargé")

# Dégeler 30 dernières couches MobileNetV2
for layer in model.layers:
    if 'mobilenet' in layer.name.lower():
        layer.trainable = True
        n = len(layer.layers)
        for i, l in enumerate(layer.layers):
            l.trainable = (i >= n - 30)
        n_act = sum(1 for l in layer.layers if l.trainable)
        print(f"   Couches dégelées : {n_act} / {n}")
        break

model.compile(
    optimizer=keras.optimizers.Adam(1e-4),
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

CKPT2 = '/kaggle/working/cnn_tchad_ft'

cb2 = [
    SaveBest(CKPT2),
    EarlyStopping(monitor='val_accuracy', patience=12,
                  restore_best_weights=True, verbose=0),
    ReduceLROnPlateau(monitor='val_loss', factor=0.3,
                      patience=5, min_lr=1e-7, verbose=1),
]

history2 = model.fit(
    gen_tr,
    epochs=40,
    validation_data=gen_va,
    callbacks=cb2,
    class_weight=class_weight_dict,
    verbose=1
)
acc_p2 = max(history2.history['val_accuracy'])

# Sauvegardes finales
model.save('/kaggle/working/model_maladie_cnn.h5')
model.save('/kaggle/working/model_maladie_cnn_final.keras')
print(f"\n✅ Fine-tuning : val_accuracy = {acc_p2*100:.2f}%")




# ══════════════════════════════════════════════════════════════════
# CELLULE 8 — Évaluation finale
# ══════════════════════════════════════════════════════════════════

print("\n" + "="*60)
print("  ÉVALUATION FINALE SUR JEU DE TEST")
print("="*60)

# Charger le meilleur modèle global
for p in [f'{CKPT2}_best.keras', '/kaggle/working/model_maladie_cnn_final.keras',
          f'{CKPT}_best.keras']:
    if os.path.exists(p):
        model = keras.models.load_model(p)
        print(f"✅ Modèle chargé : {p}")
        break

res      = model.evaluate(gen_te, verbose=0)
acc_test = res[1]

gen_te.reset()
y_prob = model.predict(gen_te, verbose=0)
y_pred = np.argmax(y_prob, axis=1)
y_true = gen_te.classes

f1m = f1_score(y_true, y_pred, average='macro',    zero_division=0)
f1w = f1_score(y_true, y_pred, average='weighted', zero_division=0)

print(f"\n  Accuracy (test)     : {acc_test*100:.2f}%")
print(f"  F1-Score (macro)    : {f1m*100:.2f}%")
print(f"  F1-Score (weighted) : {f1w*100:.2f}%")
print(f"\n{classification_report(y_true, y_pred, target_names=CLASSES_REEL, zero_division=0)}")




# ══════════════════════════════════════════════════════════════════
# CELLULE 9 — Graphiques
# ══════════════════════════════════════════════════════════════════

hist = {
    'accuracy':     history1.history['accuracy']     + history2.history['accuracy'],
    'val_accuracy': history1.history['val_accuracy'] + history2.history['val_accuracy'],
    'loss':         history1.history['loss']         + history2.history['loss'],
    'val_loss':     history1.history['val_loss']     + history2.history['val_loss'],
}
ep_p1 = len(history1.history['accuracy'])

fig, axes = plt.subplots(1, 3, figsize=(18, 5))
